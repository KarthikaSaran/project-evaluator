# --- Required: OpenAI ---
OPENAI_API_KEY=sk-your-api-key-here

# --- Required for Drive sign-in (domain-restricted links) ---
# Create an OAuth 2.0 Client ID in Google Cloud Console (type: Web application).
# See SETUP_OAUTH.md for step-by-step.
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx

# Random 32+ char string used to sign session cookies.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=replace-with-random-hex-string-at-least-32-chars

# --- Optional ---
# If your IK Workspace uses a specific Google domain, set it to make Google
# pre-fill the picker. Users can still pick another account.
# GOOGLE_HOSTED_DOMAIN=interviewkickstart.com

# If Vercel preview URLs aren't being detected correctly, pin the canonical URL:
# APP_URL=https://project-evaluator-gold.vercel.app
